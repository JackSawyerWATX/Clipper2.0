# HTTPS Configuration for Elastic Beanstalk
# This uses AWS Certificate Manager (ACM) certificates
# Configure via Elastic Beanstalk console: Load Balancer > HTTPS

option_settings:
  aws:elasticbeanstalk:environment:process:default:
    Protocol: HTTP
  aws:elasticbeanstalk:environment:process:https:
    Protocol: HTTPS
    InstancePort: 80
    HealthCheckPath: /health

# Redirect HTTP to HTTPS
files:
  "/etc/nginx/conf.d/https_redirect.conf":
    mode: "000644"
    owner: root
    group: root
    content: |
      # HTTP to HTTPS redirect (only if behind ALB with HTTPS)
      if ($http_x_forwarded_proto = "http") {
        return 301 https://$host$request_uri;
      }
