option_settings:
  aws:elasticbeanstalk:application:environment:
    PORT: "8080"
    NODE_ENV: "development"

commands:
  01_install_frontend_deps:
    command: "cd /var/app/staging && npm install --prefer-offline --no-audit 2>&1 | tee /tmp/frontend-install.log"
    ignoreErrors: false
  02_install_server_deps:
    command: "cd /var/app/staging/server && npm install --prefer-offline --no-audit 2>&1 | tee /tmp/server-install.log"
    ignoreErrors: false

container_commands:
  01_npm_install:
    command: "npm install --production=false"
    cwd: "/var/app/staging"
  02_npm_build:
    command: "npm run build"
    cwd: "/var/app/staging"
