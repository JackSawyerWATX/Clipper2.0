option_settings:
  aws:elasticbeanstalk:application:environment:
    PORT: "8080"
    NODE_ENV: "production"

container_commands:
  00_install_server_deps:
    command: "cd /var/app/staging/server && npm install --production"
    ignoreErrors: false
  01_build_frontend:
    command: "cd /var/app/staging && npm run build"
    ignoreErrors: false
  02_seed_admin:
    command: "cd /var/app/staging/server && node scripts/verifyAdminCredentials.js || true"
    ignoreErrors: true
