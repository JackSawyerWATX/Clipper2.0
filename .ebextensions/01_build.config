option_settings:
  aws:elasticbeanstalk:application:environment:
    PORT: "8080"
    NODE_ENV: "development"

commands:
  01_install_deps:
    command: "cd /var/app/staging && npm install --prefer-offline --no-audit 2>&1 | tee /tmp/root-deps.log"
    ignoreErrors: false
  02_install_server_deps:
    command: "cd /var/app/staging/server && npm install --prefer-offline --no-audit 2>&1 | tee /tmp/server-deps.log"
    ignoreErrors: false

container_commands:
  00_install_root_deps:
    command: "cd /var/app/staging && npm install --prefer-offline --no-audit 2>&1 | tee /tmp/root-install.log"
    ignoreErrors: false
  01_install_server_deps:
    command: "cd /var/app/staging/server && npm install --prefer-offline --no-audit 2>&1 | tee /tmp/server-install.log"
    ignoreErrors: false
  02_build_frontend:
    command: "cd /var/app/staging && npm run build 2>&1 | tee /tmp/build.log"
    ignoreErrors: false
  03_verify_build:
    command: "if [ -d /var/app/staging/dist ]; then echo 'SUCCESS: dist directory exists'; ls -la /var/app/staging/dist/ | head -20; else echo 'ERROR: dist directory not found'; exit 1; fi"
    ignoreErrors: false
  01_build_frontend:
    command: "cd /var/app/staging && npm run build"
    ignoreErrors: false
