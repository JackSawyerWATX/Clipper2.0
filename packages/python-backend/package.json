{
  "name": "@clipper/python-backend",
  "version": "1.0.0",
  "private": true,
  "description": "Backend API server for Clipper 2.0 (FastAPI/Python)",
  "scripts": {
    "start": "python -m uvicorn main:app --host 0.0.0.0 --port 8000",
    "dev": "python -m uvicorn main:app --host 0.0.0.0 --port 8000 --reload",
    "test": "python -m pytest tests/ -v",
    "test:watch": "python -m pytest tests/ -v --looponfail",
    "test:coverage": "python -m pytest tests/ -v --cov=. --cov-report=html"
  },
  "keywords": [
    "fastapi",
    "python",
    "api"
  ],
  "author": "",
  "license": "ISC"
}
